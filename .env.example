# MechSynth — LLM backend configuration.
# Copy to `.env` (which is gitignored) and fill in. NEVER commit `.env`.
#
#   cp .env.example .env    &&    edit .env
#
# --- Which backend the pipeline uses --------------------------------------------
# gemini (DEFAULT, D-E-8) | ollama (local qwen, the cheap regression backend) | openai_compat
MECHSYNTH_LLM_BACKEND=gemini

# --- Gemini ----------------------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey
# Either name works; GEMINI_API_KEY is checked first.
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Optional: pin the model. If unset, the client queries the API and picks the
# current pro-tier model, logging the exact string into ir.stage_log.
# MECHSYNTH_LLM_MODEL=gemini-2.5-pro

# --- Local ollama (no key needed) ------------------------------------------------
# MECHSYNTH_LLM_BACKEND=ollama
# MECHSYNTH_LLM_MODEL=qwen3-coder:latest
# MECHSYNTH_LLM_BASE_URL=http://localhost:11434
