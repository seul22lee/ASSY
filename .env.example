# MechSynth — LLM backend configuration.
# Copy to `.env` (which is gitignored) and fill in. NEVER commit `.env`.
#
#   cp .env.example .env    &&    edit .env
#
# --- Which backend the pipeline uses --------------------------------------------
# gemini (DEFAULT, D-E-8) | ollama (local qwen, the cheap regression backend) | openai_compat
MECHSYNTH_LLM_BACKEND=gemini

# --- Gemini ----------------------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey
# Either name works; GEMINI_API_KEY is checked first.
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Optional: pin the model. If unset, the client queries the API and picks the
# current model of MECHSYNTH_LLM_TIER, logging the exact string into ir.stage_log.
# MECHSYNTH_LLM_MODEL=gemini-2.5-pro
#
# Tier when MECHSYNTH_LLM_MODEL is unset: pro (default, D-E-8) | flash.
#   flash = the FREE-TIER workhorse (D-M16-5): generous free quota. The client
#   auto-resolves the newest flash model. Use for bulk/dev runs; pro for the
#   final recorded frontier column only (cost policy).
# MECHSYNTH_LLM_TIER=flash
#
# Free-tier rate limits: the client backs off on HTTP 429/503 (honouring
# Retry-After) instead of failing — so a free key just runs slower, not broken.
# Tune for a latency-tolerant free-tier run:
# MECHSYNTH_LLM_BACKOFF_RETRIES=6      # how many times to wait-and-retry
# MECHSYNTH_LLM_BACKOFF_BASE=2.0       # first backoff, seconds (doubles each retry)
# MECHSYNTH_LLM_BACKOFF_CAP=90.0       # max single wait, seconds

# --- Local ollama (no key needed) ------------------------------------------------
# MECHSYNTH_LLM_BACKEND=ollama
# MECHSYNTH_LLM_MODEL=qwen3-coder:latest
# MECHSYNTH_LLM_BASE_URL=http://localhost:11434

# --- Generic OpenAI-compatible backend (any provider: OpenRouter, Together,
#     Groq, a local vLLM/llama.cpp server, ...) --------------------------------
# Speaks POST {base}/v1/chat/completions with json_schema response_format.
# base_url + key are read from here; nothing is hardcoded.
# MECHSYNTH_LLM_BACKEND=openai_compat
# MECHSYNTH_LLM_BASE_URL=https://openrouter.ai/api      # NO trailing /v1
# MECHSYNTH_LLM_API_KEY=sk-...
# MECHSYNTH_LLM_MODEL=meta-llama/llama-3.1-70b-instruct
